<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid background color matching Compose's SplashBackground (0xFFF7FAF5) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF7FAF5" />
        </shape>
    </item>

    <!-- Agriflow Logo Centered -->
    <item
        android:drawable="@drawable/agriflow_logo"
        android:gravity="center"
        android:width="280dp"
        android:height="280dp" />
</layer-list>
